{
  "name": "sunday-school-study-companion-api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/api/src/functions/*.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "cosmos:inspect": "node scripts/study-cosmos.mjs inspect",
    "cosmos:seed": "node scripts/study-cosmos.mjs seed",
    "cosmos:migrate-curriculum-schema": "node scripts/study-cosmos.mjs migrate-curriculum-schema",
    "cosmos:prune-study-containers": "node scripts/study-cosmos.mjs prune-study-containers --yes"
  },
  "dependencies": {
    "@azure/cosmos": "^4.9.3",
    "@azure/functions": "^4.16.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.8.3"
  }
}
